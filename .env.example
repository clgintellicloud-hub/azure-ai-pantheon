# Example environment file for local development
# Copy this file to .env and fill in your values.
# IMPORTANT: .env is in .gitignore - never commit real secrets.

# Azure (use Managed Identity / OIDC in production - these are for local only)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id   # For local testing only

# MAF Orchestrator local config
FOUNDRY_ENDPOINT=https://your-foundry.services.ai.azure.com
MODEL_NAME=gpt-4o

# Endpoints for agents
# Local (with compose mocks):
HERMES_ENDPOINT=http://hermes-agent:8080
OPENCLAW_ENDPOINT=http://openclaw-agent:8080

# Production (real deployed agents on ACA):
# HERMES_ENDPOINT=https://hermes-yourapp-dev.<region>.azurecontainerapps.io
# OPENCLAW_ENDPOINT=https://openclaw-yourapp-dev.<region>.azurecontainerapps.io

# Cosmos DB for MAF state + checkpointing
# Production: Use Managed Identity (leave COSMOS_KEY empty, set USE_COSMOS_STATE=true)
# Local dev / Emulator: Provide COSMOS_ENDPOINT and COSMOS_KEY
COSMOS_ENDPOINT=https://localhost:8081  # Azure Cosmos DB Emulator default
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DATABASE=pantheon
COSMOS_CONTAINER=workflow_state
USE_COSMOS_STATE=true  # Set to false to use in-memory store (for quick local tests)
